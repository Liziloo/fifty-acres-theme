<?php
$escape = $this->plugin('escapeHtml');
$this->headLink()->appendStylesheet($this->assetUrl('css/style.css'));
$this->headScript()->prependFile('https://code.jquery.com/jquery-3.7.1.min.js');

// Fetch dynamic assets from Theme Settings
$logoUrl = $this->themeSettingAssetUrl('logo');
$bannerUrl = $this->themeSettingAssetUrl('banner');
$bannerHeight = $this->themeSetting('banner_height', 400);
$bannerVisibility = $this->themeSetting('banner_visibility', 'home');
$footerText = $this->themeSetting('footer_text');

// Robust Homepage Check (Fixes Fatal Error)
$isHome = false;
if ($this->status()->isSiteRequest() &&
    $this->params()->fromRoute('controller') === 'index' &&
    $this->params()->fromRoute('action') === 'index') {
    $isHome = true;
}

// Visibility Logic
$showBanner = false;
if ($bannerUrl) {
    if ($bannerVisibility === 'all' || ($bannerVisibility === 'home' && $isHome)) {
        $showBanner = true;
    }
}
?>
<?= $this->doctype(); ?>
<html lang="<?= $this->lang(); ?>">
<head>
    <?= $this->headMeta(); ?>
    <?= $this->headTitle(); ?>

    <!-- 3. THE CSS MAILBOX: Modules deliver their CSS here -->
    <?= $this->headLink(); ?>

    <!-- 4. THE INLINE SCRIPT MAILBOX: Modules deliver their config here -->
    <?= $this->headStyle(); ?>
</head>
<body>
    <?= $this->userBar(); ?>

    <div id="site-wrapper">
        <aside id="sidebar">
            <div class="branding">
                <a href="<?= $site->url(); ?>">
                    <?php if ($logoUrl): ?>
                        <img src="<?= $logoUrl; ?>" alt="<?= $escape($this->themeSetting('logo_alt')); ?>">
                    <?php else: ?>
                        <h1><?= $escape($site->title()); ?></h1>
                    <?php endif; ?>
                </a>
            </div>

            <nav id="main-nav">
                <?= $site->publicNav()->menu(); ?>
            </nav>

            <div id="sidebar-footer">
                <span class="est">EST. 1856</span>
                <?php echo $this->partial('common/search-form'); ?>
            </div>
        </aside>

        <main id="content-stage">
            <?php if ($showBanner): ?>
                <div id="global-banner"
                     role="img"
                     aria-label="<?= $escape($this->themeSetting('banner_alt')); ?>"
                     style="background-image: url('<?= $bannerUrl; ?>'); height: <?= $bannerHeight; ?>px;">
                </div>
            <?php endif; ?>

            <div id="main-content">
                <?= $this->content; ?>
            </div>

            <footer id="site-footer">
                <?= $footerText ? $escape($footerText) : ''; ?>
            </footer>
        </main>
    </div>


    <!-- 5. THE JS MAILBOX: Modules deliver their JS here -->
    <!-- Placing this at the bottom ensures the DOM is ready for modules to fire -->
    <?= $this->headScript(); ?>
</body>
</html>
