<?php
$escape = $this->plugin('escapeHtml');
// 1. Queue jQuery (Mandatory for modules)
$this->headScript()->prependFile('https://code.jquery.com/jquery-3.7.1.min.js');
// 2. Queue Theme CSS
$this->headLink()->appendStylesheet($this->assetUrl('css/style.css'));

// Fetch GUI Settings
$logoUrl = $this->themeSettingAssetUrl('logo');
$bannerUrl = $this->themeSettingAssetUrl('banner');
$bannerHeight = $this->themeSetting('banner_height', 400);
$bannerVisibility = $this->themeSetting('banner_visibility', 'home');
$footerText = $this->themeSetting('footer_text');

// Robust Route Check
$isHome = ($this->params()->fromRoute('controller') === 'index' && $this->params()->fromRoute('action') === 'index');
$showBanner = ($bannerUrl && ($bannerVisibility === 'all' || $isHome));
?>
<?= $this->doctype(); ?>
<html lang="<?= $this->lang(); ?>">
<head>
    <?= $this->headMeta(); ?>
    <?= $this->headTitle(); ?>
    <!-- Module CSS (Slick, etc) loads here -->
    <?= $this->headLink(); ?>
    <?= $this->headStyle(); ?>
</head>
<body>
    <!-- Admin bar stays outside the flex wrapper -->
    <?= $this->userBar(); ?>

    <div id="site-wrapper">
        <aside id="sidebar">
            <div class="branding">
                <a href="<?= $site->url(); ?>">
                    <?php if ($logoUrl): ?>
                        <img src="<?= $logoUrl; ?>" alt="<?= $escape($this->themeSetting('logo_alt')); ?>">
                    <?php else: ?>
                        <h1><?= $escape($site->title()); ?></h1>
                    <?php endif; ?>
                </a>
            </div>
            <nav id="main-nav"><?= $site->publicNav()->menu(); ?></nav>
            <div id="sidebar-footer">
                <span class="est">EST. 1856</span>
                <?= $this->partial('common/search-form'); ?>
            </div>
        </aside>

        <main id="content-stage">
            <?php if ($showBanner): ?>
                <div id="global-banner"
                     role="img"
                     aria-label="<?= $escape($this->themeSetting('banner_alt')); ?>"
                     style="background-image: url('<?= $bannerUrl; ?>'); height: <?= $bannerHeight; ?>px;">
                </div>
            <?php endif; ?>

            <div id="main-content">
                <?= $this->content; ?>
            </div>

            <footer id="site-footer"><?= $footerText ? $escape($footerText) : ''; ?></footer>
        </main>
    </div>

    <!-- Module JS (Slick engine) loads here -->
    <?= $this->headScript(); ?>
</body>
</html>